{
  "name": "agentic-workflows-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:5x": "node scripts/run-e2e-5x.mjs",
    "test:e2e:ui": "playwright test --ui",
    "generate:types": "node scripts/generate-ts-types.mjs",
    "generate:types:check": "node scripts/generate-ts-types.mjs && git diff --exit-code -- src/api/events.generated.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.2",
    "@xyflow/react": "^12.10.2",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "autoprefixer": "^10.5.0",
    "jsdom": "^25.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
