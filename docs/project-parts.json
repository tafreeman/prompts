  "integration_points": [
    {
      "from": "ui",
      "to": "runtime",
      "type": "REST API",
      "details": "16 endpoints under /api/, Vite dev proxy on port 5173 → 8010"
    },
    {
      "from": "ui",
      "to": "runtime",
      "type": "WebSocket",
      "details": "/ws/execution/{run_id} for real-time execution streaming with 500-event replay buffer"
    },
    {
      "from": "ui",
      "to": "runtime",
      "type": "SSE",
      "details": "/api/runs/{run_id}/stream for server-sent event streaming"
    },
    {
      "from": "runtime",
      "to": "tools",
      "type": "Python import",
      "details": "tools.llm.llm_client.LLMClient (aliased as LegacyClient), tools.llm.langchain_adapter, tools.agents.benchmarks.*"
    },
    {
      "from": "eval",
      "to": "tools",
      "type": "Python import (lazy)",
      "details": "tools.llm.llm_client.LLMClient via adapters, tools.agents.benchmarks via datasets.py"
    }
  ]
}
