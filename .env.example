PROMPTEVAL_ALLOW_REMOTE=1

# Local environment variables for LLM providers.
#
# IMPORTANT:
# - Do NOT store real secrets in this repo.
# - Prefer using `.env.example` as a template.
# - This `.env` file is gitignored, but keep it parseable (KEY=VALUE only).

# GitHub Models API (optional; used when running gh:* models)
# GitHub Models API (optional; used when running gh:* models)
# Get your GitHub token: https://github.com/settings/tokens
GITHUB_TOKEN= 

HF_TOKEN= 
 # OpenAI API (paid; remote)
# Get your OpenAI API key: https://platform.openai.com/api-keys
OPENAI_API_KEY= 

 # Azure AI Foundry / Azure OpenAI (remote)
# Get your Azure OpenAI key: https://portal.azure.com/#view/Microsoft_Azure_ProjectOxford/CognitiveServicesHub/~/Keys
 # If you see keys with _0 through _n, these are backup keys. Use the next one if the first hits its rate limit.
AZURE_OPENAI_API_KEY_0=
AZURE_OPENAI_ENDPOINT_0=

 # Azure AI Services endpoints (optional)
# Get your Azure AI Services endpoint: https://portal.azure.com/#view/Microsoft_Azure_ProjectOxford/CognitiveServicesHub/~/Keys
AZURE_AI_SERVICES_ENDPOINT=
AZURE_COGNITIVE_ENDPOINT=

 # Gemini API (remote)
# Get your Gemini API key: https://aistudio.google.com/app/apikey
 # Gemini Model Rate Limits (reference)
 # Gemini 2.5 Flash Lite:        RPM 10   | TPM 250K   | RPD 20
 # Gemini 2.5 Flash TTS:        RPM 3    | TPM 10K    | RPD 10
 # Gemini 2.5 Flash:            RPM 5    | TPM 250K   | RPD 20
 # Gemini 3 Flash:              RPM 5    | TPM 250K   | RPD 20
 # Gemini Robotics ER 1.5:      RPM 10   | TPM 250K   | RPD 20
 # Gemma 3 12B:                 RPM 30   | TPM 15K    | RPD 14.4K
 # Gemma 3 1B:                  RPM 30   | TPM 15K    | RPD 14.4K
 # Gemma 3 27B:                 RPM 30   | TPM 15K    | RPD 14.4K
 # Gemma 3 2B:                  RPM 30   | TPM 15K    | RPD 14.4K
 # Gemma 3 4B:                  RPM 30   | TPM 15K    | RPD 14.4K
 # Gemini Embedding 1:          RPM 100  | TPM 30K    | RPD 1K
 # Gemini 2.5 Flash Native Audio Dialog: RPM Unlimited | TPM 1M | RPD Unlimited
GEMINI_API_KEY= 
GEMINI_API_KEY_0= 
gemini_API_KEY_1= 
GEMINI_API_KEY_2= 

 # Anthropic Claude (paid)
# Get your Anthropic API key: https://console.anthropic.com/settings/keys
 # Anthropic Model Rate Limits (reference)
 # Model:                RPM  | Input TPM | Output TPM | Context Limit
 # Claude Opus 4/4.1/4.5: 5   | 10K       | 4K         | ≤ 200k
 # Claude Haiku 4.x:      5   | 10K       | 4K         | ≤ 200k
 # Claude Sonnet 4/4.5:   5   | 10K       | 4K         | ≤ 200k
 # Claude Sonnet 3.7:     5   | 10K       | 4K         | ≤ 200k
 # Claude Haiku 3.5:      5   | 25K       | 5K         | ≤ 200k
 # Claude Haiku 3:        5   | 25K       | 5K         | ≤ 200k
 # Batch requests: 5/min across all models
 # Web search tool: 30/sec across all models
 # Files API storage: 100 GB/org
ANTHROPIC_API_KEY= 
ANTHROPIC_API_KEY_0= 
 # Local model & dataset paths
# AI Dev Gallery ONNX models (auto-detected)
LOCAL_MODEL_PATH= 
 # Available ONNX models:
 # - microsoft--Phi-4-mini-instruct-onnx
 # - microsoft--Phi-3.5-mini-instruct-onnx
 # - microsoft--Phi-3.5-vision-instruct-onnx
 # - microsoft--Phi-3-medium-4k-instruct-onnx-cpu
 # - microsoft--Phi-3-mini-4k-instruct-onnx
 # - microsoft--Phi-3-vision-128k-instruct-onnx
 # - microsoft--mistral-7b-instruct-v0.2-ONNX
 # - CompVis--stable-diffusion-v1-4
 # - khmyznikov--whisper-int8-cpu-ort.onnx
 # - sentence-transformers--all-MiniLM-L6-v2
 # - sentence-transformers--all-MiniLM-L12-v2

 # HuggingFace cache (datasets & model hub)
HF_CACHE_PATH= 
HF_DATASETS_CACHE= 
 # Cached datasets:
 # - Dahoas/code-review-instruct-critique-revision-python
 # - iamtarun/python_code_instructions_18k_alpaca
 # - iamtarun/code_instructions_120k_alpaca
 # - cfahlgren1/react-code-instructions
 # - princeton-nlp/SWE-bench_Lite
 # - princeton-nlp/SWE-bench_Verified
 # - openai/openai_humaneval
 # - google-research-datasets/mbpp

 # Ollama local models
OLLAMA_HOST= 
OLLAMA_MODELS= 
OLLAMA_API_KEY= 

 # Installed Ollama models:
 # Local:       deepseek-r1:8b, deepseek-r1:14b, gemma3:1b, gemma3:4b,
 #              gpt-oss:20b, llama2-uncensored:latest, phi4-reasoning:latest,
 #              qwen2.5-coder:14b, qwen3:8b, qwen3-coder:30b
 # Cloud-only:  deepseek-v3.1:671b-cloud, deepseek-v3.2:cloud, glm-4.6:cloud,
 #              gpt-oss:20b-cloud, gpt-oss:120b-cloud, minimax-m2:cloud,
 #              qwen3-coder:480b-cloud, qwen3-vl:235b-cloud

 # Windows AI (Phi Silica) - optional LAF Token Configuration
# Get your Phi Silica LAF token: https://www.phi-silica.com/ (see documentation for details)
PHI_SILICA_LAF_FEATURE_ID=
PHI_SILICA_LAF_TOKEN=
PHI_SILICA_LAF_ATTESTATION=
