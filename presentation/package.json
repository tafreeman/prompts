{
  "name": "genai-advocacy-hub",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:single": "vite build --mode single-file && node scripts/build-single-file.mjs",
    "export:html": "npm run build:single",
    "export:images": "node scripts/export-images.mjs",
    "export:pdf": "node scripts/export-pdf.mjs",
    "export:all": "npm run export:html && npm run export:images && npm run export:pdf",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-onboarding": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@vitejs/plugin-react": "^4.2.0",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.52.0",
    "pptxgenjs": "^4.0.1",
    "storybook": "^10.2.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.0"
  }
}
